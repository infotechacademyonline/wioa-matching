# Postgres
DATABASE_URL=postgres://user:password@localhost:5432/wioa_matching

# Zoho CRM (for pulling participant records)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Geocoding — Census Geocoder needs no key (US addresses only, free).
# If you switch to Google, set GOOGLE_GEOCODE_API_KEY and update src/geocode.js.
GOOGLE_GEOCODE_API_KEY=

# Email (Brevo SMTP shown as example — swap for whatever you already use)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WIOA Program <noreply@yourprogram.org>"

# Base URL used to build the participant checklist link in emails
APP_BASE_URL=https://yourapp.example.com

# Simple shared password protecting the staff dashboard for now
STAFF_DASHBOARD_PASSWORD=change-me
